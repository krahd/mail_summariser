{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Backend",
      "type": "shell",
      "command": "./start_backend.sh",
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^.*$", "file": 1, "location": 2, "message": 3 },
        "background": { "activeOnStart": true, "beginsPattern": "^.*uvicorn.*", "endsPattern": "Uvicorn running" }
      },
      "presentation": { "echo": true, "reveal": "always", "focus": false, "panel": "shared", "showReuseMessage": true }
    },
    {
      "label": "Start Backend with Reinstall",
      "type": "shell",
      "command": "./start_backend.sh",
      "args": ["-R"],
      "isBackground": true,
      "problemMatcher": { "pattern": { "regexp": "^.*$", "file": 1, "location": 2, "message": 3 }, "background": { "activeOnStart": true, "beginsPattern": "^.*Creating.*virtual environment.*", "endsPattern": "Uvicorn running" } },
      "presentation": { "echo": true, "reveal": "always", "focus": false, "panel": "shared", "showReuseMessage": true }
    },
    {
      "label": "Start Webapp",
      "type": "shell",
      "command": "${workspaceFolder}/backend/.venv/bin/python",
      "args": ["-m", "http.server", "8000", "--directory", "webapp"],
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "presentation": { "echo": true, "reveal": "always", "focus": false, "panel": "dedicated" },
      "problemMatcher": { "pattern": { "regexp": "^.*$", "file": 1, "location": 2, "message": 3 }, "background": { "activeOnStart": true, "beginsPattern": "Serving HTTP on", "endsPattern": "Serving HTTP on" } }
    },
    {
      "label": "Start Backend (Debug)",
      "type": "shell",
      "command": "${workspaceFolder}/backend/.venv/bin/python",
      "args": ["-m", "debugpy", "--listen", "5678", "--wait-for-client", "-m", "uvicorn", "backend.app:app", "--reload", "--host", "127.0.0.1", "--port", "8766"],
      "options": { "cwd": "${workspaceFolder}/backend" },
      "isBackground": true,
      "problemMatcher": { "pattern": { "regexp": "^.*$", "file": 1, "location": 2, "message": 3 }, "background": { "activeOnStart": true, "beginsPattern": "^.*debugpy.*", "endsPattern": "Uvicorn running" } },
      "presentation": { "echo": true, "reveal": "always", "focus": false, "panel": "shared", "showReuseMessage": true }
    },
    {
      "label": "Start Full Stack",
      "type": "shell",
      "dependsOn": ["Start Backend", "Start Webapp"],
      "dependsOrder": "sequence",
      "presentation": { "echo": true, "reveal": "always", "focus": false, "panel": "shared" }
    },
    {
      "label": "Build Backend Binary (macOS)",
      "type": "shell",
      "command": "python3",
      "args": ["scripts/build_backend_binary.py", "--platform", "macos", "--arch", "arm64"],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Build Backend Binary (Linux)",
      "type": "shell",
      "command": "python3",
      "args": ["scripts/build_backend_binary.py", "--platform", "linux", "--arch", "x64"],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Build Backend Binary (Windows)",
      "type": "shell",
      "command": "python3",
      "args": ["scripts/build_backend_binary.py", "--platform", "windows", "--arch", "x64"],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Build macOS App Archive",
      "type": "shell",
      "command": "./scripts/build_macos_app.sh",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Validate Full Stack",
      "type": "shell",
      "command": "./scripts/validate_full_stack.sh",
      "presentation": { "reveal": "always", "panel": "shared" }
    }
  ]
}
