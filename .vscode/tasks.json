{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Backend",
      "type": "shell",
      "command": "./start_backend.sh",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*uvicorn.*",
          "endsPattern": "^.*Uvicorn running.*"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      }
    },
    {
      "label": "Start Backend with Reinstall",
      "type": "shell",
      "command": "./start_backend.sh",
      "args": ["-R"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Creating.*virtual environment.*",
          "endsPattern": "^.*Uvicorn running.*"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      }
    },
    {
      "label": "Build Backend Binary (macOS)",
      "type": "shell",
      "command": "python3",
      "args": [
        "scripts/build_backend_binary.py",
        "--platform",
        "macos",
        "--arch",
        "arm64"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      }
    },
    {
      "label": "Build Backend Binary (Linux)",
      "type": "shell",
      "command": "python3",
      "args": [
        "scripts/build_backend_binary.py",
        "--platform",
        "linux",
        "--arch",
        "x64"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      }
    },
    {
      "label": "Build Backend Binary (Windows)",
      "type": "shell",
      "command": "python3",
      "args": [
        "scripts/build_backend_binary.py",
        "--platform",
        "windows",
        "--arch",
        "x64"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      }
    },
    {
      "label": "Build macOS App Archive",
      "type": "shell",
      "command": "./scripts/build_macos_app.sh",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      }
    }
  ]
}
